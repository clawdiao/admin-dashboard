# Admin Dashboard — Environment Variables

# Database (same NeonDB as Open-Trafego)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Admin Auth
ADMIN_JWT_SECRET="your-admin-jwt-secret-change-this"
ADMIN_JWT_EXPIRES_IN="1h"

# Stripe (for subscription management)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
PORT="3001"
CORS_ORIGIN="http://localhost:5173,https://seu-frontend.vercel.app"

# Email (Resend/SendGrid) — for notifications to admins
RESEND_API_KEY="re_..."
FROM_EMAIL="admin@yourdomain.com"

# Logging
LOG_LEVEL="info"
